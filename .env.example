# Chave privada da sua carteira de DESENVOLVIMENTO (nunca use a carteira principal!)
# Obtenha via MetaMask → Detalhes da conta → Exportar chave privada
PRIVATE_KEY=0xSUA_CHAVE_PRIVADA_AQUI

# URL do nó RPC da Sepolia — crie uma app gratuita em https://alchemy.com
ALCHEMY_SEPOLIA_URL=https://eth-sepolia.g.alchemy.com/v2/SUA_API_KEY_AQUI

# Project ID do WalletConnect — crie grátis em https://cloud.walletconnect.com
VITE_WALLETCONNECT_PROJECT_ID=SEU_PROJECT_ID_AQUI

# Endereço do contrato após o deploy (preencha depois do deploy)
VITE_CONTRACT_ADDRESS=0xENDERECO_DO_CONTRATO_APOS_DEPLOY
